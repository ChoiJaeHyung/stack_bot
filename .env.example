# Google Chat AI 비서 설정 템플릿
# 이 파일을 복사하여 .env 파일을 생성하세요: copy .env.example .env

# Google Cloud Service Account 키 경로
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# GCP 프로젝트 ID
GCP_PROJECT_ID=your-project-id

# Pub/Sub 구독 ID
PUBSUB_SUBSCRIPTION_ID=your-subscription-id

# 사용자 인증: STACK API에서 동적으로 검증 (SSO 매칭)
# 허용 도메인 (이 도메인의 이메일만 STACK 검증 시도)
GCHAT_ALLOWED_DOMAIN=example.com

# 봇 이름
BOT_NAME=AI비서

# 폴링 간격 (초) - 기본값: 10초
GCHAT_POLLING_INTERVAL=10

# STACK API
STACK_API_URL=https://your-stack-instance.example.com
STACK_API_KEY=your-stack-api-key

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Agent 설정
OPENAI_TIMEOUT=60
STACK_API_TIMEOUT=15
MAX_TOOL_TURNS=10
TRUNCATE_MAX_LEN=8000
WORKING_LOCK_TIMEOUT=180
GCHAT_MESSAGE_LIMIT=4096
